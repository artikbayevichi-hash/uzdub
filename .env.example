# UZDUB — muhit sozlamalari (.env.example ni .env ga nusxalang)

# Ma'lumotlar bazasi
DB_HOST=localhost
DB_NAME=uzdub
DB_USER=root
DB_PASS=

# Admin (database.sql import qilingandan keyin o'zgartiring)
# Default: admin / UzdubAdmin2026!

# Telegram bot
TG_BOT_TOKEN=
TG_CHAT_ID=

# Click to'lov
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_USER_ID=
CLICK_SECRET_KEY=

# Uzum to'lov
UZUM_MERCHANT_ID=
UZUM_SECRET_KEY=

# Qo'lda to'lov karta
CARD_NUMBER=8600XXXX0000XXXX
CARD_OWNER=UZDUB

# Ollama AI
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_MAX_CONCURRENT=1

# Sayt URL (Open Graph va PWA uchun)
SITE_URL=http://localhost/uzdub

# Google OAuth (Google Cloud Console'dan oling)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cron maxfiy kalit (premium muddat tekshiruvi uchun)
CRON_SECRET_KEY=ozgartiring_kerak_123

# ZIP yuklab olish maxfiy kaliti (localhost'dan tashqarida ruxsat berish uchun)
ZIP_SECRET_KEY=
